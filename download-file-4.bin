<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MTN Bundles - Buy Data Instantly</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #FFCC00;
            --primary-dark: #E6B800;
            --secondary: #0066CC;
            --dark: #1a1a1a;
            --dark-light: #2a2a2a;
            --text: #ffffff;
            --text-muted: #b0b0b0;
            --success: #00C851;
            --danger: #ff4444;
        }

        body {
            font-family: 'Work Sans', sans-serif;
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0a0a0a 100%);
            color: var(--text);
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Header */
        header {
            background: rgba(26, 26, 26, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 204, 0, 0.2);
            padding: 20px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: 'Orbitron', sans-serif;
            font-size: 24px;
            font-weight: 800;
            color: var(--text);
        }

        .logo-accent {
            color: var(--primary);
        }

        nav {
            display: flex;
            gap: 32px;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        nav a:hover, nav a.active {
            color: var(--primary);
        }

        .btn-login {
            background: var(--primary);
            color: var(--dark);
            border: none;
            padding: 12px 32px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            transition: all 0.3s ease;
        }

        .btn-login:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero {
            padding: 100px 0;
            text-align: center;
        }

        .hero h1 {
            font-family: 'Orbitron', sans-serif;
            font-size: 72px;
            font-weight: 900;
            margin-bottom: 24px;
            line-height: 1.1;
        }

        .hero .accent {
            color: var(--primary);
            text-shadow: 0 0 40px rgba(255, 204, 0, 0.5);
        }

        .hero p {
            font-size: 20px;
            color: var(--text-muted);
            margin-bottom: 40px;
        }

        .cta-button {
            background: var(--primary);
            color: var(--dark);
            border: none;
            padding: 18px 48px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            transition: all 0.3s ease;
        }

        .cta-button:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(255, 204, 0, 0.5);
        }

        /* Bundles Grid */
        .bundles-section {
            padding: 80px 0;
        }

        .section-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 48px;
            text-align: center;
            margin-bottom: 60px;
            background: linear-gradient(135deg, var(--text) 0%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .bundles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 32px;
        }

        .bundle-card {
            background: linear-gradient(135deg, var(--dark-light) 0%, rgba(42, 42, 42, 0.6) 100%);
            border: 2px solid rgba(255, 204, 0, 0.2);
            border-radius: 20px;
            padding: 40px 32px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
        }

        .bundle-card:hover {
            transform: translateY(-12px);
            border-color: var(--primary);
            box-shadow: 0 20px 60px rgba(255, 204, 0, 0.3);
        }

        .bundle-card.popular {
            border-color: var(--primary);
            background: linear-gradient(135deg, rgba(255, 204, 0, 0.1) 0%, var(--dark-light) 100%);
        }

        .popular-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--primary);
            color: var(--dark);
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
            font-family: 'Orbitron', sans-serif;
        }

        .bundle-size {
            font-family: 'Orbitron', sans-serif;
            font-size: 56px;
            font-weight: 900;
            color: var(--primary);
            margin-bottom: 12px;
        }

        .bundle-validity {
            color: var(--text-muted);
            margin-bottom: 32px;
        }

        .bundle-price {
            font-size: 40px;
            font-weight: 800;
            margin-bottom: 32px;
            font-family: 'Orbitron', sans-serif;
        }

        .buy-button {
            width: 100%;
            background: var(--primary);
            color: var(--dark);
            border: none;
            padding: 16px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            transition: all 0.3s ease;
        }

        .buy-button:hover {
            background: var(--primary-dark);
            transform: scale(1.05);
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--dark);
            border: 2px solid var(--primary);
            border-radius: 24px;
            padding: 48px;
            max-width: 500px;
            width: 90%;
        }

        .modal-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 32px;
            color: var(--primary);
            margin-bottom: 32px;
            text-align: center;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .form-group input {
            width: 100%;
            background: rgba(42, 42, 42, 0.6);
            border: 2px solid rgba(255, 204, 0, 0.2);
            color: var(--text);
            padding: 14px 16px;
            border-radius: 8px;
            font-size: 16px;
        }

        .form-group input:focus {
            outline: none;
            border-color: var(--primary);
        }

        .submit-button {
            width: 100%;
            background: var(--primary);
            color: var(--dark);
            border: none;
            padding: 16px;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            margin-top: 16px;
        }

        .close-modal {
            background: transparent;
            border: 2px solid var(--danger);
            color: var(--danger);
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 16px;
            width: 100%;
        }

        /* Footer */
        footer {
            background: var(--dark);
            border-top: 1px solid rgba(255, 204, 0, 0.2);
            padding: 40px 0 24px;
            margin-top: 80px;
            text-align: center;
            color: var(--text-muted);
        }

        /* Notification */
        .notification {
            position: fixed;
            top: 100px;
            right: 20px;
            background: var(--dark-light);
            border: 2px solid var(--primary);
            padding: 16px 24px;
            border-radius: 12px;
            color: var(--text);
            z-index: 1001;
            display: none;
            animation: slideIn 0.3s ease-out;
        }

        .notification.show {
            display: block;
        }

        @keyframes slideIn {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 40px;
            }

            nav {
                display: none;
            }

            .bundles-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Notification -->
    <div id="notification" class="notification"></div>

    <!-- Header -->
    <header>
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    MTN<span class="logo-accent">Bundles</span>
                </div>
                <nav>
                    <a href="#home" class="active">Home</a>
                    <a href="#bundles">Bundles</a>
                </nav>
                <button class="btn-login" onclick="showLogin()">Login</button>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="container">
            <h1>
                Fast. Reliable. <span class="accent">Affordable.</span>
            </h1>
            <p>Get instant MTN data bundles at the best prices</p>
            <button class="cta-button" onclick="scrollToBundles()">Browse Bundles</button>
        </div>
    </section>

    <!-- Bundles Section -->
    <section id="bundles" class="bundles-section">
        <div class="container">
            <h2 class="section-title">Choose Your Bundle</h2>
            <div class="bundles-grid">
                <div class="bundle-card">
                    <div class="bundle-size">1GB</div>
                    <div class="bundle-validity">1 Day</div>
                    <div class="bundle-price">₦500</div>
                    <button class="buy-button" onclick="buyBundle('1GB', 500)">Buy Now</button>
                </div>

                <div class="bundle-card">
                    <div class="bundle-size">2GB</div>
                    <div class="bundle-validity">3 Days</div>
                    <div class="bundle-price">₦900</div>
                    <button class="buy-button" onclick="buyBundle('2GB', 900)">Buy Now</button>
                </div>

                <div class="bundle-card popular">
                    <div class="popular-badge">Popular</div>
                    <div class="bundle-size">5GB</div>
                    <div class="bundle-validity">7 Days</div>
                    <div class="bundle-price">₦2,000</div>
                    <button class="buy-button" onclick="buyBundle('5GB', 2000)">Buy Now</button>
                </div>

                <div class="bundle-card popular">
                    <div class="popular-badge">Popular</div>
                    <div class="bundle-size">10GB</div>
                    <div class="bundle-validity">14 Days</div>
                    <div class="bundle-price">₦3,500</div>
                    <button class="buy-button" onclick="buyBundle('10GB', 3500)">Buy Now</button>
                </div>

                <div class="bundle-card">
                    <div class="bundle-size">20GB</div>
                    <div class="bundle-validity">30 Days</div>
                    <div class="bundle-price">₦6,000</div>
                    <button class="buy-button" onclick="buyBundle('20GB', 6000)">Buy Now</button>
                </div>

                <div class="bundle-card">
                    <div class="bundle-size">50GB</div>
                    <div class="bundle-validity">30 Days</div>
                    <div class="bundle-price">₦12,000</div>
                    <button class="buy-button" onclick="buyBundle('50GB', 12000)">Buy Now</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Purchase Modal -->
    <div id="purchaseModal" class="modal">
        <div class="modal-content">
            <h2 class="modal-title">Complete Purchase</h2>
            <div id="bundleDetails" style="margin-bottom: 24px; text-align: center;">
                <p style="font-size: 18px; color: var(--text-muted);">Bundle: <strong id="selectedBundle" style="color: var(--primary);"></strong></p>
                <p style="font-size: 24px; font-family: 'Orbitron', sans-serif; color: var(--primary); margin-top: 8px;">₦<span id="selectedPrice"></span></p>
            </div>
            <form onsubmit="processPurchase(event)">
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" id="phoneNumber" placeholder="080XXXXXXXX" required>
                </div>
                <div class="form-group">
                    <label>Email (Optional)</label>
                    <input type="email" id="email" placeholder="your@email.com">
                </div>
                <button type="submit" class="submit-button">Pay Now</button>
                <button type="button" class="close-modal" onclick="closeModal()">Cancel</button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2024 MTNBundles. All rights reserved.</p>
            <p style="margin-top: 8px; font-size: 14px;">Fast, Reliable, Affordable Data Bundles</p>
        </div>
    </footer>

    <script>
        let currentBundle = { size: '', price: 0 };

        function scrollToBundles() {
            document.getElementById('bundles').scrollIntoView({ behavior: 'smooth' });
        }

        function showNotification(message) {
            const notification = document.getElementById('notification');
            notification.textContent = message;
            notification.classList.add('show');
            setTimeout(() => {
                notification.classList.remove('show');
            }, 4000);
        }

        function buyBundle(size, price) {
            currentBundle = { size, price };
            document.getElementById('selectedBundle').textContent = size;
            document.getElementById('selectedPrice').textContent = price.toLocaleString();
            document.getElementById('purchaseModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('purchaseModal').classList.remove('active');
            document.getElementById('phoneNumber').value = '';
            document.getElementById('email').value = '';
        }

        function processPurchase(event) {
            event.preventDefault();
            const phone = document.getElementById('phoneNumber').value;
            const email = document.getElementById('email').value;

            // Here you would integrate with your payment gateway
            // For demo purposes, we'll just show a success message
            closeModal();
            showNotification(`Successfully purchased ${currentBundle.size} bundle!`);

            // In production, you would:
            // 1. Send data to your backend
            // 2. Initialize payment with Paystack/Flutterwave
            // 3. Redirect to payment page
            // 4. Handle payment callback
            // 5. Deliver bundle automatically
        }

        function showLogin() {
            alert('Login functionality will be connected to your backend API');
        }
    </script>
</body>
</html>
